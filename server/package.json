{
  "name": "peertask-server",
  "version": "1.0.0",
  "description": "PeerTask backend — Express + native MongoDB driver + Passport session auth",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file-if-exists=.env server.js",
    "dev": "nodemon --exec \"node --env-file-if-exists=.env\" server.js",
    "seed": "node --env-file-if-exists=.env seed_1000.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "author": "Anurag & Sanjay",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "mongodb": "^6.8.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.7",
    "prettier": "^3.8.3"
  }
}
